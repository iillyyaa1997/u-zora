        }
      }
    },
    "Enable “Time-Sensitive Notifications” for uZora there so critical alerts can pierce Focus.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Enable “Time-Sensitive Notifications” for uZora there so critical alerts can pierce Focus."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Включите там «Уведомления, чувствительные ко времени» для uZora, чтобы критические оповещения пробивали Focus."
          }
        }
      }
    }
