    "Caution: removes ~/Library/Caches. Some apps store login/session state there and may need to re-authenticate or rebuild settings.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Caution: removes ~/Library/Caches. Some apps store login/session state there and may need to re-authenticate or rebuild settings."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Осторожно: удаляет ~/Library/Caches. Некоторые приложения хранят там данные входа/сессии и могут потребовать повторной авторизации или пересоздания настроек."
          }
        }
      }
    },
