    "Delete local Time Machine snapshots (tmutil deletelocalsnapshots). Reversible: macOS recreates snapshots automatically.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Delete local Time Machine snapshots (tmutil deletelocalsnapshots). Reversible: macOS recreates snapshots automatically."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Удалить локальные снимки Time Machine (tmutil deletelocalsnapshots). Обратимо: macOS пересоздаёт снимки автоматически."
          }
        }
      }
    },
